<?xml version="1.0" encoding="UTF-8"?>
<!-- UR + OnRobot SRDF (with binary patches to ur_moveit_config) -->
<!-- The 'name' arg is passed by MoveIt launch (e.g. name:=ur5e or name:=ur10e) -->
<!-- This sets the planning group to <name>_manipulator -->
<!-- Requires binary patches: see apply_binary_patches.sh -->

<robot xmlns:xacro="http://wiki.ros.org/xacro" name="$(arg name)">
  <xacro:arg name="name" default="ur"/>
  
  <!-- Include the full implementation -->
  <xacro:include filename="$(find ur_onrobot)/srdf/ur_with_onrobot_generic.srdf.xacro"/>
</robot>
