<?xml version="1.0" ?>
<robot name="onrobot_2fg14" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find ur_onrobot)/urdf/materials.xacro" />

<xacro:macro name="onrobot_2fg14_gripper" params="prefix finger_configuration=outwards">

  <xacro:property name="config" value="${finger_configuration}"/>
  
  <!-- NOTE: Using FG7 meshes as placeholder until FG14-specific meshes are available -->
  <!-- FG14 is approximately 2x larger in stroke (140mm vs 70mm) -->
  
  <xacro:if value="${config == 'outwards'}">
    <link name="${prefix}base_link">
      <inertial>
        <!-- FG14 mass: ~2.5kg (scaled from FG7 1.265kg) -->
        <origin xyz="-4.898915958379213e-05 2.84756960271082e-06 0.06811082379774974" rpy="0 0 0"/>
        <mass value="2.5"/>
        <inertia ixx="0.003008" iyy="0.003624" izz="0.002106" ixy="-0.0" iyz="0.0" ixz="-6e-06"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ur_onrobot/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ur_onrobot/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}right_finger_link">
      <inertial>
        <origin xyz="0.017874296677847158 0.02949104051991925 0.01523421548622829" rpy="0 0 0"/>
        <mass value="0.046438766711844576"/>  <!-- 2x FG7 finger mass -->
        <inertia ixx="1.2e-05" iyy="1e-05" izz="4e-06" ixy="-0.0" iyz="-0.0" ixz="2e-06"/>
      </inertial>
      <visual>
        <origin xyz="0.054361 0.029494 -0.12005" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ur_onrobot/meshes/right_finger_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision name="right_finger_collision">
        <origin xyz="0.054361 0.029494 -0.12005" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ur_onrobot/meshes/right_finger_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}left_finger_link">
      <inertial>
        <origin xyz="0.004247703322119739 0.029496959480080673 0.015234215486237948" rpy="0 0 0"/>
        <mass value="0.046438766711844576"/>  <!-- 2x FG7 finger mass -->
        <inertia ixx="1.2e-05" iyy="1e-05" izz="4e-06" ixy="-0.0" iyz="0.0" ixz="-2e-06"/>
      </inertial>
      <visual>
        <origin xyz="-0.032239 0.029494 -0.12005" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ur_onrobot/meshes/left_finger_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision name="left_finger_collision">
        <origin xyz="-0.032239 0.029494 -0.12005" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ur_onrobot/meshes/left_finger_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}left_finger_joint" type="prismatic">
      <origin xyz="0.032239 -0.029494 0.12005" rpy="0 0 0"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}left_finger_link"/>
      <axis xyz="-1.0 0.0 0.0"/>
      <!-- FG14: 0-140mm stroke = 0.070m per finger (vs FG7: 0.019m) -->
      <limit lower="0.0" upper="0.070" effort="300" velocity="0.45"/>
    </joint>

    <joint name="${prefix}right_finger_joint" type="prismatic">
      <origin xyz="-0.054361 -0.029494 0.12005" rpy="0 0 0"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}right_finger_link"/>
      <axis xyz="1.0 0.0 0.0"/>
      <!-- Symmetric movement with mimic joint -->
      <limit lower="-0.070" upper="0.070" effort="300" velocity="0.45"/>
      <mimic joint="${prefix}left_finger_joint" multiplier="1.0"/>
    </joint>
  </xacro:if>

  <xacro:if value="${config == 'inwards'}">
    <link name="${prefix}base_link">
      <inertial>
        <origin xyz="-4.8989159583623376e-05 2.847569602502098e-06 0.06811082379775064" rpy="0 0 0"/>
        <mass value="2.5"/>
        <inertia ixx="0.003008" iyy="0.003624" izz="0.002106" ixy="-0.0" iyz="0.0" ixz="-6e-06"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ur_onrobot/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ur_onrobot/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}right_finger_link">
      <inertial>
        <origin xyz="0.029847703322119633 0.029496959480087837 0.015234215486232036" rpy="0 0 0"/>
        <mass value="0.046438766711844576"/>
        <inertia ixx="1.2e-05" iyy="1e-05" izz="4e-06" ixy="-0.0" iyz="0.0" ixz="-2e-06"/>
      </inertial>
      <visual>
        <origin xyz="0.054361 0.029494 -0.12005" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ur_onrobot/meshes/right_finger_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="0.054361 0.029494 -0.12005" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ur_onrobot/meshes/right_finger_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}left_finger_link">
      <inertial>
        <origin xyz="-0.007725703322151688 0.029491040519911117 0.015234215486238503" rpy="0 0 0"/>
        <mass value="0.046438766711844576"/>
        <inertia ixx="1.2e-05" iyy="1e-05" izz="4e-06" ixy="-0.0" iyz="-0.0" ixz="2e-06"/>
      </inertial>
      <visual>
        <origin xyz="-0.032239 0.029494 -0.12005" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ur_onrobot/meshes/left_finger_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="-0.032239 0.029494 -0.12005" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://ur_onrobot/meshes/left_finger_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}left_finger_joint" type="prismatic">
      <origin xyz="0.032239 -0.029494 0.12005" rpy="0 0 0"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}left_finger_link"/>
      <axis xyz="-1.0 0.0 0.0"/>
      <limit upper="0.0" lower="-0.070" effort="300" velocity="0.45"/>
    </joint>
    
    <joint name="${prefix}right_finger_joint" type="prismatic">
      <origin xyz="-0.054361 -0.029494 0.12005" rpy="0 0 0"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}right_finger_link"/>
      <axis xyz="1.0 0.0 0.0"/>
      <limit lower="-0.070" upper="0.070" effort="300" velocity="0.45"/>
      <mimic joint="${prefix}left_finger_joint" multiplier="1.0"/>
    </joint>

  </xacro:if>
</xacro:macro>

<!-- Default parameters for standalone visualization -->
<xacro:arg name="prefix" default=""/>
<xacro:arg name="finger_configuration" default="outwards"/>

<!-- Instantiate the gripper by default for standalone visualization -->
<xacro:onrobot_2fg14_gripper prefix="$(arg prefix)" finger_configuration="$(arg finger_configuration)"/>

</robot>
